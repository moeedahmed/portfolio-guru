  },
  "navigation_chrome": {
    "skip_to_content": "button.btn.kz-skip-navigation",
    "icon_menu": "#icon-menu",
    "logout_button": "button:contains(\"Logout\")[ng-click=\"avatarCardCtrl.logout()\"]",
    "view_profile_button": "a.btn.bg-white.btn-xs.text-primary",
    "settings_button": "a.btn.btn-xs.border.border-primary.text-primary",
    "trust_device_modal": ".btn-info"
  },
  "common": {
    "page_title": "h1",
    "ng_repeat_attr": "[ng-repeat]",
    "loading_spinner": ".spinner, .loading",
    "twitter_typeahead": ".twitter-typeahead",
    "ui_select": ".ui-select-container",
    "online_indicator_prefix_in_title": [
      "\ud83d\udfe2",
