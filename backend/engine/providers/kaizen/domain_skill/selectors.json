{
  "site": {
    "name": "RCEM Kaizen ePortfolio",
    "base_url": "https://kaizenep.com",
    "auth_url": "https://auth.kaizenep.com",
    "platform": "risr/advance",
    "stack": "AngularJS 1.x + Formly + ui-select + Twitter Typeahead, Bootstrap 3",
    "org": "org_rcem",
    "client": "kaizen",
    "verified": "2026-05-16 by Moeed Ahmed"
  },
  "authentication": {
    "interaction_url_pattern": "https://auth.kaizenep.com/interaction/{uuid}/login",
    "username_selector": "input[name=\"login\"]",
    "password_selector": "input[name=\"password\"]",
    "submit_selector": "button[type=\"submit\"]",
    "hidden_fields": {
      "org": "input[name=\"org\"]",
      "client": "input[name=\"client\"]",
      "type": "input[name=\"type\"]",
      "uuid": "input[name=\"uuid\"]",
      "lang": "input[name=\"lang\"]"
    },
    "login_redirect": "/dashboard",
    "trust_device_buttons": {
      "trust": "button.btn-info:contains(\"I trust this device\")",
      "shared": "button.btn-info:contains(\"This is a shared device\")"
    },
    "double_character_workaround": "Use nativeInputValueSetter \u2014 fill_input doubles chars on Formly inputs. See kaizen_set_field in agent_helpers.py."
  },
  "routes": {
    "dashboard": "/dashboard",
    "timeline_list": "/events/list/{category}",
    "timeline_all": "/events/list/All",
    "event_view": "/events/view/{event_uuid}",
    "event_view_section": "/events/view-section/{section_uuid}",
    "event_new_picker": "/events/new",
    "event_new_form": "/events/new-section/{event_type_uuid}",
    "goals_list_curriculum": "/goals/list/{curriculum_encoded}",
    "goals_list_all": "/goals/list/all",
    "goals_work_detail": "/goals/work/{goal_uuid}",
    "reports_index": "/report_templates",
    "report_run": "/report_templates/run/{template_uuid}",
    "report_org_coverage": "/reports/view/organisation/coverage/{report_uuid}",
    "files": "/files",
    "faqs": "/faqs",
    "profile_view": "/profile/view",
    "settings_offline": "/settings/offline",
    "settings_diagnose": "/settings/test",
    "activities": "/activities",
    "inbox": "/inbox"
  },
  "timeline": {
    "categories": {
      "all": "All",
      "assessments": "Assessments",
      "training_post_supervisor": "Post%20%26%20Supervisor",
      "educational_reviews": "Educational%20Review%20%26%20Meetings",
      "progression": "Progression",
      "procedural_logs": "Procedural%20Logs",
      "reflections": "Reflection",
      "msf": "MSF",
      "teaching": "Teaching%20%26%20Education",
      "research_audit_qi": "Research%2C%20Audit%20%26%20QI",
      "management": "Manage%2C%20Administer%20%26%20Lead",
      "elearning": "e-Learning",
      "exams": "Exams",
      "absence": "Absence",
      "cct": "CCT",
      "documents": "Documents"
    },
    "selectors": {
      "row": ".row.event-inner",
      "row_title": ".row.event-inner h2.entry-title",
      "row_title_text": ".row.event-inner h2.entry-title span[data-ng-bind-html]",
      "row_link": ".row.event-inner a[router-link]",
      "row_right_meta": ".row.event-inner .col-right .list-inline.list-unstyled",
      "row_state_badge": ".row.event-inner .event-section-progress-state",
      "total_count_regex": "(\\d+)\\s+items",
      "search_input": "input[name=\"text\"][placeholder=\"Start typing to search\"]",
      "bookmark_search_input": "input[name=\"title\"][placeholder=\"Bookmark current search\"]",
      "filter_dropdowns": ".ui-select-container.ui-select-multiple",
      "create_new_button": "button.btn-success:contains(\"Create new\")"
    }
  },
  "event_detail_readonly": {
    "page_title": "h1",
    "field_group": ".form-text__form-group, .form-readonly__form-group",
    "field_section_heading": ".form-text__heading",
    "field_section_description": ".form-text__description",
    "field_label": ".form-text__control-label, .control-label",
    "field_value": ".form-text__field-value, dd, .field-value",
    "readonly_wrapper": ".form-readonly, .form-readonly--fancy",
    "progress_state": ".event-section-progress-state",
    "progress_state_complete": ".event-section-progress-state--complete",
    "tag_chip": ".event-tag",
    "filled_in_by": ".event-users",
    "audit_log_toggle": "button:contains(\"Show audit log\")",
    "download_pdf_button": "button:contains(\"Download PDF\"), a:contains(\"Download PDF\")",
    "back_button": "button:contains(\"Back\"), a:contains(\"Back\")",
    "edit_button": "button:contains(\"Edit\"), a:contains(\"Edit\")"
  },
  "event_new_form": {
    "wrapper": "form[name=\"newForm\"]",
    "start_date": "input#startDate",
    "end_date": "input#endDate",
    "description": "textarea#event-description, textarea[name=\"event-description\"]",
    "field_by_uuid": "input#{uuid}, textarea#{uuid}, select#{uuid}",
    "field_group": ".form-group",
    "field_label": ".form-group .control-label",
    "ui_select_container": ".ui-select-container",
    "assessor_input": "input#invites",
    "assessor_listbox": "#invites_listbox",
    "tag_button": "button:contains(\"Add tags\")",
    "link_to_dropdown": "button.dropdown-toggle:contains(\"Link to ...\")",
    "curriculum_buttons": [
      "button:contains(\"All added curricula\")",
      "button:contains(\"Higher EM curriculum (2025 Update)\")",
      "button:contains(\"Intermediate Curriculum 2021\")",
      "button:contains(\"Higher Curriculum 2021\")",
      "button:contains(\"PEM sub-specialty curriculum Reformatted (AUG16-JUL18)\")"
    ],
    "upload_button": "button.btn-info:contains(\"Upload\")",
    "submit_button": "button.btn-success.btn-raised:contains(\"Send to assessor\")",
    "submit_ng_click": "eventCtrl.save(eventCtrl.form, 'publish')"
  },
  "event_type_picker": {
    "url": "/events/new",
    "h1": "What would you like to create?",
    "type_link_selector": "a[ng-click=\"newEventCtrl.getRouteForEventType(eventType._id)\"]",
    "click_method": "el.click()  (href is / so do not goto_url)"
  },
  "goals": {
    "list_page": {
      "h1": "h1",
      "slo_link": "a[href*=\"/goals/work/\"]",
      "slo_heading": "h3"
    },
    "work_page": {
      "h1": "h1",
      "target_repeat": "[ng-repeat=\"target in goalCtrl.goal.targets track by target._id\"]",
      "target_title": "h5.entry-title.text-gray",
      "target_progress_count": ".col-sm-12.text-info.ng-binding",
      "target_link_event_button": "button:contains(\"Link event to this target\")",
      "target_select_existing_button": "button:contains(\"Select existing event\")",
      "target_create_new_button": "button:contains(\"Create new\")",
      "sibling_sidebar": "[ng-repeat=\"goal in list.items track by goal.doc._id\"]"
    }
  },
  "reports": {
    "index": {
      "h1": "Reports",
      "report_link": "a[href*=\"/reports\"], a[href*=\"/report_templates/\"]",
      "section_heading": "h2, h3"
    },
    "coverage": {
      "h1": "h1",
      "node_repeat": "[ng-repeat=\"node in nodes track by node._id\"]",
      "state_repeat": "[ng-repeat=\"state in states track by $index\"]"
    }
  },
  "files": {
    "url": "/files",
    "uses_timeline_selectors": true,
    "row": ".row.event-inner",
    "filename_title": "h2.entry-title",
    "linked_event_text_regex": "linked to:\\s+(.+)"
  },
  "dashboard": {
    "url": "/dashboard",
    "h1": "h1",
    "stage_h2": "h2",
    "widget": ".widget.panel.panel-default",
    "widget_title": ".widget .panel-title, .widget h2.panel-title",
    "widget_body": ".widget .panel-body",
    "widget_titles": [
      "2025 Update on its way!",
      "Alerts",
      "Quick notes",
      "Profile",
      "Higher Clinical Specialty Learning outcomes (2025 Update)",
      "Higher Generic Specialty Learning Outcomes (2025 Update)",
      "Higher EM procedural skills (2025 Update)",
      "Create event",
      "All Higher Clinical SLO Entrustments 2025 update",
      "Progression: Please read",
      "Need Help?"
